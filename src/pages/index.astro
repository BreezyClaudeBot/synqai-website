    name:        'AI Voice Assistant',
    description: 'An AI voice assistant that answers after-hours calls, handles common questions, and collects caller information.',
    idealFor:    'Medical clinics, dental offices, wellness centres, law offices, real estate offices, and after-hours service businesses.',
    features: [
      'Answers after-hours incoming calls',
      'Collects caller information and reason for calling',
      'Answers common business questions',
      'Sends call summaries directly to your inbox',
      'Dedicated Canadian or US voice number',
    ],
  },
];

const industries = [
  {
    label: 'Clinics',
    image: '/industries/clinics.jpg',
    summary: 'Capture appointment requests around the clock.',
    useCases: [
      'Answer treatment and pricing questions instantly',
      'Handle new patient inquiries after hours',
      'Collect booking details before staff follow-up',
      'Route urgent inquiries to the right contact',
    ],
  },
  {
    label: 'Restaurants',
    image: '/industries/restaurants.jpg',
    summary: 'Handle reservations and guest inquiries automatically.',
    useCases: [
      'Respond to menu and dietary questions',
      'Capture reservation requests 24/7',
      'Handle catering and private event inquiries',
      'Convert missed calls into confirmed bookings',
    ],
  },
  {
    label: 'Auto Shops',
    image: '/industries/auto-shops.jpg',
    summary: 'Never miss a service call or estimate request.',
    useCases: [
      'Answer common service and maintenance questions',
      'Capture quote requests with vehicle details',
      'Follow up missed calls via SMS instantly',
      'Pre-qualify jobs before team callback',
    ],
  },
  {
    label: 'Home Services',
    image: '/industries/home-services.jpg',
    summary: 'Capture leads from every call and inquiry.',
    useCases: [
      'Collect job details and customer contact info',
      'Handle after-hours emergency inquiries',
      'Answer service area and availability questions',
      'Turn website visitors into booked estimates',
    ],
  },
  {
    label: 'Agencies',
    image: '/industries/agencies.jpg',
    summary: 'Qualify and route inbound leads instantly.',
    useCases: [
      'Qualify leads by budget and service needs',
      'Answer service offering and timeline questions',
      'Book discovery calls automatically',
      'Route qualified prospects to the right team',
    ],
  },
];

const comparisons = [
  {
    without: 'Missed calls go straight to voicemail',
    with: 'Every missed call triggers an instant SMS follow-up',
  },
  {
    without: 'Customers wait hours — or never hear back',
    with: 'Responses in under 60 seconds, any time of day',
  },
  {
    without: 'Hiring more staff just to answer the phone',
    with: 'AI handles the volume — no added headcount',
  },
  {
    without: 'After-hours inquiries lost until morning',
    with: '24/7 coverage across calls, texts, and chat',
  },
];

const marqueeItems = [
  'Dental Clinics', 'Medical Practices', 'Auto Shops', 'Home Services',
  'Restaurants', 'Wellness Spas', 'Law Offices', 'Real Estate',
  'Contractors', 'Fitness Studios', 'Veterinary Clinics', 'Salons',
];

const CONTACT = 'ali@getsynq.ca';
---

<Base>

  <style is:global>
    /* ── Rotating hero text ── */
    .rotate-wrap {
      display: inline-block;
      overflow: hidden;
      vertical-align: bottom;
      height: 1.12em;
      position: relative;
    }
    .rotate-inner {
      display: flex;
      flex-direction: column;
      animation: rotate-words 8s cubic-bezier(.65,0,.35,1) infinite;
    }
    .rotate-inner span {
      color: #2dd4bf;
      display: block;
      height: 1.12em;
      line-height: 1.12;
    }
    .rotate-inner-light span {
      color: #5eead4;
      display: block;
      height: 1.12em;
      line-height: 1.12;
    }
    @keyframes rotate-words {
      0%,20%  { transform: translateY(0); }
      25%,45% { transform: translateY(-25%); }
      50%,70% { transform: translateY(-50%); }
      75%,95% { transform: translateY(-75%); }
      100%    { transform: translateY(-100%); }
    }

    /* ── Marquee ── */
    @keyframes marquee {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .marquee-track {
      display: flex;
      width: max-content;
      animation: marquee 55s linear infinite;
    }
    .marquee-track:hover { animation-play-state: paused; }

    /* ── Hero headline ── */
    .hero-h1 {
      font-size: clamp(2rem, 4vw, 3.25rem) !important;
      line-height: 1.06 !important;
      letter-spacing: -0.04em !important;
    }

    /* ── Dot grid (dark backgrounds) ── */
    .dot-grid::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(circle, rgba(255,255,255,.08) 1px, transparent 1px);
      background-size: 24px 24px;
      pointer-events: none;
    }

    /* ── Dot grid (cream / light backgrounds) ── */
    .dot-grid-light::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(circle, rgba(0,0,0,.055) 1px, transparent 1px);
      background-size: 24px 24px;
      pointer-events: none;
    }

    /* ── Chat widget message animation ── */
    .chat-msg {
      opacity: 0;
      transform: translateY(8px);
      animation: msg-in .4s ease forwards;
    }
    @keyframes msg-in {
      to { opacity: 1; transform: translateY(0); }
    }
    .chat-msg:nth-child(1) { animation-delay: .4s; }
    .chat-msg:nth-child(2) { animation-delay: 1.6s; }
    .chat-msg:nth-child(3) { animation-delay: 3.2s; }

    .typing-dot {
      width: 5px; height: 5px; border-radius: 50%; background: #6b7280;
      animation: blink .9s ease-in-out infinite;
    }
    .typing-dot:nth-child(2) { animation-delay: .2s; }
    .typing-dot:nth-child(3) { animation-delay: .4s; }
    @keyframes blink {
      0%,80%,100% { opacity:.25; transform: scale(.85); }
      40%          { opacity:1;   transform: scale(1); }
    }

    .typing-wrap {
      opacity: 0;
      animation: typing-show .3s ease forwards, typing-hide .3s ease forwards;
      animation-delay: 1.2s, 2.8s;
    }
    @keyframes typing-show { to { opacity: 1; } }
    @keyframes typing-hide { to { opacity: 0; } }

    .badge-pop {
      opacity: 0;
      transform: scale(.8) translateY(6px);
      animation: badge-in .4s cubic-bezier(.34,1.56,.64,1) forwards;
    }
    .badge-pop.delay-1 { animation-delay: 4s; }
    .badge-pop.delay-2 { animation-delay: 5.6s; }
    @keyframes badge-in {
      to { opacity: 1; transform: scale(1) translateY(0); }
    }

    /* ── How It Works: animated channel cards ── */
    .hiw-chat-msg {
      opacity: 0;
      transform: translateY(6px);
      transition: opacity .35s ease, transform .35s ease;
    }
    .hiw-chat-msg.show {
      opacity: 1;
      transform: translateY(0);
    }
    .hiw-voice-msg,
    .hiw-voice-summary {
      opacity: 0;
      transform: translateY(5px);
      transition: opacity .4s ease, transform .4s ease;
    }
    .hiw-voice-msg.show,
    .hiw-voice-summary.show {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── How It Works: Missed-Call SMS animation ── */
    .hiw-sms-screen {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity .4s ease;
      pointer-events: none;
    }
    .hiw-sms-screen.active {
      opacity: 1;
    }
    .hiw-sms-field {
      opacity: 0;
      transform: translateY(5px);
      transition: opacity .35s ease, transform .35s ease;
    }
    .hiw-sms-field.show {
      opacity: 1;
      transform: translateY(0);
    }
    .hiw-sms-pulse {
      animation: sms-pulse 1.4s ease-in-out infinite;
    }
    @keyframes sms-pulse {
      0%, 100% { opacity: .4; transform: scale(1); }
      50%      { opacity: 1;  transform: scale(1.35); }
    }
    .hiw-sms-connector-line {
      transition: background-color .4s ease;
    }
    .hiw-sms-dot {
      position: absolute;
      top: 50%;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      margin-top: -3px;
      opacity: 0;
      transition: background-color .3s ease;
    }
    .hiw-sms-dot.animate-ltr {
      animation: sms-dot-ltr 1.6s ease-in-out infinite;
    }
    .hiw-sms-dot.animate-rtl {
      animation: sms-dot-rtl 1.6s ease-in-out infinite;
    }
    @keyframes sms-dot-ltr {
      0%   { left: 0%;   opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 1; }
      100% { left: 100%; opacity: 0; }
    }
    @keyframes sms-dot-rtl {
      0%   { left: 100%; opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 1; }
      100% { left: 0%;   opacity: 0; }
    }
    .hiw-sms-xbadge {
      opacity: 0;
      transform: scale(.5);
      transition: opacity .3s ease, transform .3s cubic-bezier(.34,1.56,.64,1);
    }
    .hiw-sms-xbadge.show {
      opacity: 1;
      transform: scale(1);
    }

    /* ── Before/after comparison rows ── */
    .compare-row {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity .5s ease, transform .5s ease;
    }
    .compare-row.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .compare-strike {
      position: relative;
    }
    .compare-strike::after {
      content: '';
      position: absolute;
      left: 0;
      top: 50%;
      width: 0;
      height: 2px;
      background: #ef4444;
      transition: width .6s ease .3s;
    }
    .compare-row.visible .compare-strike::after {
      width: 100%;
    }
    .compare-with {
      opacity: 0;
      transform: translateX(-8px);
      transition: opacity .4s ease, transform .4s ease;
    }
    .compare-row.visible .compare-with {
      opacity: 1;
      transform: translateX(0);
      transition-delay: .6s;
    }

    /* ── Animated stats ── */
    .stat-item {
      opacity: 0;
      transform: translateY(10px);
      animation: stat-in .5s ease forwards;
    }
    .stat-item:nth-child(1) { animation-delay: .6s; }
    .stat-item:nth-child(2) { animation-delay: .8s; }
    .stat-item:nth-child(3) { animation-delay: 1.0s; }
    .stat-item:nth-child(4) { animation-delay: 1.2s; }
    @keyframes stat-in {
      to { opacity: 1; transform: translateY(0); }
    }

    /* ── Editorial buttons ── */
    .btn-ed {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      text-decoration: none;
      background: none;
      border: none;
      cursor: pointer;
      font-family: 'Plus Jakarta Sans', Inter, system-ui, sans-serif;
      transition: gap 0.25s cubic-bezier(.34,1.56,.64,1);
    }
    .btn-ed:hover { gap: 16px; }
    .btn-ed .ed-arrow {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 14px;
      transition: transform 0.25s cubic-bezier(.34,1.56,.64,1);
    }
    .btn-ed:hover .ed-arrow { transform: translateX(4px); }
    .btn-ed-light { color: #fff; }
    .btn-ed-light .ed-arrow { background: rgba(255,255,255,0.12); color: #fff; }
    .btn-ed-light:hover .ed-arrow { background: rgba(255,255,255,0.2); }
    .btn-ed-teal { color: #0d9488; }
    .btn-ed-teal .ed-arrow { background: #0d9488; color: #fff; }
    .btn-ed-teal:hover .ed-arrow { background: #0f766e; }
    .btn-ed-dark { color: #1c1917; }
    .btn-ed-dark .ed-arrow { background: #1c1917; color: #fff; }
    .btn-ed-dark:hover .ed-arrow { background: #44403c; }
    .btn-ed-sm { font-size: 10px; gap: 8px; }
    .btn-ed-sm .ed-arrow { width: 24px; height: 24px; font-size: 11px; }

    /* ── Stat icon animations ── */
    .clock-min  { transform-origin: 12px 12px; animation: clock-min 3s linear infinite; }
    .clock-hour { transform-origin: 12px 12px; animation: clock-hour 36s linear infinite; }
    @keyframes clock-min  { to { transform: rotate(360deg); } }
    @keyframes clock-hour { to { transform: rotate(360deg); } }

    .msg-sent {
      opacity: 0;
      transform: translateY(4px) scale(.95);
      animation: msg-appear 2.5s ease infinite;
    }
    .msg-ago { opacity: 0; animation: ago-appear 2.5s ease infinite; }
    @keyframes msg-appear {
      0%,10%   { opacity:0; transform:translateY(4px) scale(.95); }
      25%,75%  { opacity:1; transform:translateY(0) scale(1); }
      90%,100% { opacity:0; transform:translateY(0) scale(1); }
    }
    @keyframes ago-appear {
      0%,30%   { opacity:0; }
      50%,75%  { opacity:1; }
      90%,100% { opacity:0; }
    }

    .person-l { animation: gather-l 3s ease-in-out infinite; }
    .person-r { animation: gather-r 3s ease-in-out infinite; }
    .person-c { animation: person-pulse 3s ease-in-out infinite; }
    @keyframes gather-l {
      0%,15%  { transform: translateX(-14px); opacity:0; }
      45%,70% { transform: translateX(0); opacity:1; }
      90%,100%{ transform: translateX(-14px); opacity:0; }
    }
    @keyframes gather-r {
      0%,25%  { transform: translateX(14px); opacity:0; }
      55%,70% { transform: translateX(0); opacity:1; }
      90%,100%{ transform: translateX(14px); opacity:0; }
    }
    @keyframes person-pulse {
      0%,40%  { transform: scale(1); }
      55%     { transform: scale(1.15); }
      70%,100%{ transform: scale(1); }
    }

    .bill { animation: bill-fall 2.2s ease-in infinite; opacity:0; }
    .bill:nth-child(1) { animation-delay: 0s; }
    .bill:nth-child(2) { animation-delay: 0.7s; }
    .bill:nth-child(3) { animation-delay: 1.4s; }
    @keyframes bill-fall {
      0%   { transform: translateY(-8px) rotate(-6deg); opacity:0; }
      12%  { opacity:1; }
      50%  { transform: translateY(14px) rotate(4deg); opacity:1; }
      85%  { opacity:1; }
      100% { transform: translateY(32px) rotate(-3deg); opacity:0; }
    }
  </style>


  <!-- ════════════════════════════════════════
       HEADER
       ════════════════════════════════════════ -->
  <header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-stone-950/95 backdrop-blur-md border-b border-white/5">
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between gap-6">

      <a href="#">
        <img src="/logo.png?v=20260509b" alt="SynqAI" class="h-8 w-auto" />
      </a>

      <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
        <a href="#how"       class="text-sm text-stone-400 hover:text-white transition-colors">How It Works</a>
        <a href="#outcomes"  class="text-sm text-stone-400 hover:text-white transition-colors">What You Gain</a>
        <a href="#built-for" class="text-sm text-stone-400 hover:text-white transition-colors">Built For</a>
        <a href="#solutions" class="text-sm text-stone-400 hover:text-white transition-colors">Solutions</a>
      </nav>

      <a href={`mailto:${CONTACT}?subject=SynqAI%20Sales%20Inquiry`} class="btn-ed btn-ed-light btn-ed-sm">
        Contact Sales <span class="ed-arrow">→</span>
      </a>
    </div>
  </header>


  <main>

    <!-- ════════════════════════════════════════
         HERO
         ════════════════════════════════════════ -->
    <section
      class="relative dot-grid bg-stone-950 overflow-hidden pt-20 pb-0"
      aria-label="Hero"
    >

      <!-- Ambient glow -->
      <div class="pointer-events-none absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] rounded-full bg-teal/[0.07] blur-[120px]" aria-hidden="true"></div>

      <div class="relative max-w-4xl mx-auto px-6 w-full text-center">

        <!-- Eyebrow -->
        <div class="flex items-center justify-center gap-4 mb-5">
          <span class="w-8 h-px bg-teal/50"></span>
          <p class="text-teal text-xs font-semibold tracking-[0.18em] uppercase font-sans">AI-Powered Front Desk</p>
          <span class="w-8 h-px bg-teal/50"></span>
        </div>

        <!-- Headline -->
        <h1 class="hero-h1 font-heading text-white font-bold mb-4">
          Never Miss Another <span class="rotate-wrap" aria-label="Customer">
            <span class="rotate-inner" aria-hidden="true">
              <span>Customer</span>
              <span>Call</span>
              <span>Booking</span>
              <span>Customer</span>
            </span>
          </span>
        </h1>

        <p class="text-stone-400 text-base leading-relaxed mb-6 font-sans max-w-xl mx-auto">
          Synq automatically handles calls, texts, and website messages — capturing every opportunity without adding headcount
        </p>

        <div class="flex flex-col items-center gap-4 mb-6">
          <a href={`mailto:${CONTACT}?subject=SynqAI%20Sales%20Inquiry`} class="btn-ed btn-ed-teal">
            Talk to Sales <span class="ed-arrow">→</span>
          </a>
          <a href="#how" class="flex flex-col items-center gap-2 group" aria-label="See how it works">
            <span class="text-[9px] font-semibold tracking-[0.16em] uppercase text-white/30 font-sans group-hover:text-white/60 transition-colors">How It Works</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/30 group-hover:text-white/60 transition-all group-hover:translate-y-1 duration-300"><polyline points="6 9 12 15 18 9"/></svg>
          </a>
        </div>

        <!-- Chatbot demo video -->
        <div class="flex justify-center">
          <div class="rounded-t-2xl bg-stone-800/60 border border-white/10 border-b-0 p-3 pb-0">
            <video
              autoplay
              loop
              muted
              playsinline
              class="rounded-t-xl"
              style="width: 300px; height: auto; display: block;"
            >
              <source src="/chatbot-demo.mov" type="video/mp4" />
            </video>
          </div>
        </div>

      </div>

      <!-- Stats row -->
      <div class="relative max-w-7xl mx-auto px-6 mt-6">
        <div class="grid grid-cols-2 sm:grid-cols-4 border-t border-teal/20">

          <!-- 24/7 — ticking clock -->
          <div class="stat-item px-6 py-4 text-center">
            <div class="flex justify-center mb-3" aria-hidden="true">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="12" r="10" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"/>
                <circle cx="12" cy="12" r="1.5" fill="#2dd4bf"/>
                <line x1="12" y1="3" x2="12" y2="5" stroke="rgba(255,255,255,0.25)" stroke-width="1.2" stroke-linecap="round"/>
                <line x1="12" y1="19" x2="12" y2="21" stroke="rgba(255,255,255,0.25)" stroke-width="1.2" stroke-linecap="round"/>
                <line x1="3" y1="12" x2="5" y2="12" stroke="rgba(255,255,255,0.25)" stroke-width="1.2" stroke-linecap="round"/>
                <line x1="19" y1="12" x2="21" y2="12" stroke="rgba(255,255,255,0.25)" stroke-width="1.2" stroke-linecap="round"/>
                <line class="clock-hour" x1="12" y1="12" x2="12" y2="7.5" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
                <line class="clock-min" x1="12" y1="12" x2="12" y2="5.5" stroke="#2dd4bf" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
            </div>
            <p class="font-heading text-2xl font-bold text-white mb-1 tracking-tight">24/7</p>
            <p class="text-stone-500 text-xs font-sans">Coverage</p>
          </div>

          <!-- <1 min — message sent -->
          <div class="stat-item px-6 py-4 text-center border-l border-teal/20">
            <div class="flex flex-col items-center justify-end mb-3 gap-1" style="height:36px;" aria-hidden="true">
              <div class="flex items-center gap-1 self-start ml-2">
                <div style="width:28px;height:10px;background:rgba(255,255,255,0.12);border-radius:6px 6px 6px 2px;"></div>
              </div>
              <div class="flex items-end gap-1.5 self-end mr-2">
                <div class="msg-ago" style="font-size:7px;color:rgba(255,255,255,0.35);font-family:sans-serif;white-space:nowrap;">1s ago</div>
                <div class="msg-sent" style="width:34px;height:10px;background:#0d9488;border-radius:6px 6px 2px 6px;"></div>
              </div>
            </div>
            <p class="font-heading text-2xl font-bold text-white mb-1 tracking-tight">&lt;1 min</p>
            <p class="text-stone-500 text-xs font-sans">Response</p>
          </div>

          <!-- 3× — people gathering -->
