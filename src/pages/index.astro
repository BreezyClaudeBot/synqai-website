const addons = [
  {
    eyebrow:     'MISSED-CALL FOLLOW-UP',
    name:        'Missed-Call SMS Recovery',
    description: 'Automatically text missed callers and collect their information — so no lead disappears to voicemail.',
    idealFor:    'Clinics, dental offices, repair shops, contractors, home service businesses, and spas.',
    features: [
