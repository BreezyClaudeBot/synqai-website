    <script is:inline>
      (() => {
        const cadBtn = document.querySelector('[data-currency-btn="cad"]');
        const usdBtn = document.querySelector('[data-currency-btn="usd"]');
        const cadEls = document.querySelectorAll('[data-price-cad]');
        const usdEls = document.querySelectorAll('[data-price-usd]');

        const activeOn  = ['bg-slate-900', 'text-white', 'border-slate-900'];
        const activeOff = ['border-slate-300', 'text-slate-600'];

        function setCAD() {
          cadEls.forEach(el => el.classList.remove('hidden'));
          usdEls.forEach(el => el.classList.add('hidden'));
          cadBtn.classList.add(...activeOn);
          cadBtn.classList.remove(...activeOff);
          usdBtn.classList.remove(...activeOn);
          usdBtn.classList.add(...activeOff);
        }

        function setUSD() {
          usdEls.forEach(el => el.classList.remove('hidden'));
          cadEls.forEach(el => el.classList.add('hidden'));
          usdBtn.classList.add(...activeOn);
          usdBtn.classList.remove(...activeOff);
          cadBtn.classList.remove(...activeOn);
          cadBtn.classList.add(...activeOff);
        }

        cadBtn?.addEventListener('click', setCAD);
        usdBtn?.addEventListener('click', setUSD);
        setCAD();
      })();
    </script>


