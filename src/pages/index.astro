---
import Base from '../layouts/Base.astro';

const chatbots = [
  {
    eyebrow: 'WEBSITE Q&A',
    name:    'SynqLite',
    badge:   null,
    description: 'A smart website chatbot that answers customer questions instantly using your business content — available around the clock.',
    idealFor:    'Restaurants, coffee shops, auto shops, retail stores, salons, and simple service businesses.',
    features: [
      'Answers common questions from your website content',
      'Fully branded website chat widget',
      'Basic updates and ongoing support',
      'Appointment request support',
      'Chat logging and history',
      'SMS & voice add-ons available',
    ],
  },
  {
    eyebrow: 'LEAD CAPTURE + CHATBOT',
    name:    'SynqPlus',
    badge:   'Most Popular',
    description: 'An advanced chatbot that captures leads, collects appointment request details, and keeps your team informed in real time.',
    idealFor:    "Doctors' offices, dental clinics, spas, wellness clinics, med spas, consultants, and appointment-based businesses.",
    features: [
      'Everything in SynqLite',
      'Captures name, email, phone, and inquiry details',
      'Appointment request forms with preferred dates and times',
      'Full chat logs for review and improvement',
