    <script is:inline>
      (() => {
        const toggleRoot = document.querySelector('[data-currency-toggle]');
        if (!toggleRoot) return;

        const buttons = Array.from(toggleRoot.querySelectorAll('[data-currency-option]'));
        const priceEls = Array.from(document.querySelectorAll('[data-price]'));
        const setupNote = document.querySelector('[data-setup-note]');

        const setCurrency = (currency) => {
          buttons.forEach((button) => {
            const isActive = button.getAttribute('data-currency-option') === currency;
            button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
            button.classList.toggle('bg-slate-900', isActive);
            button.classList.toggle('text-white', isActive);
            button.classList.toggle('text-slate-600', !isActive);
          });

          priceEls.forEach((priceEl) => {
            const nextValue = priceEl.getAttribute(`data-${currency}`);
            if (nextValue) priceEl.textContent = nextValue;
          });

          if (setupNote) {
            const nextNote = setupNote.getAttribute(`data-${currency}`);
            if (nextNote) setupNote.textContent = nextNote;
          }
        };

        buttons.forEach((button) => {
          button.addEventListener('click', () => {
            const currency = button.getAttribute('data-currency-option');
            if (!currency) return;
            setCurrency(currency);
          });
        });

        setCurrency('usd');
      })();
    </script>


