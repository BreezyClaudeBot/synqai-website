                <p class="text-slate-500 text-xs">{s.label}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>


    <!-- ════════════════════════════════════════
         HOW IT WORKS
         ════════════════════════════════════════ -->
    <section id="how" class="py-24 bg-white" aria-labelledby="how-heading">
      <div class="max-w-6xl mx-auto px-6">

