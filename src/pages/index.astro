      var CHAT_LOOP  = 10500;
      function runChat() {
        chatMsgs.forEach(function(m) { m.classList.remove('show'); });
        chatDelays.forEach(function(d, i) {
          setTimeout(function() { if (chatMsgs[i]) chatMsgs[i].classList.add('show'); }, d);
        });
        setTimeout(runChat, CHAT_LOOP);
      }
      if (chatMsgs.length) setTimeout(runChat, 300);

      // 2. Voice — inbox email summary
      var voiceSummary = document.querySelector('.hiw-voice-summary');
      var voiceMsgs    = Array.from(document.querySelectorAll('.hiw-voice-msg'));
      var VOICE_LOOP   = 10000;
      function runVoice() {
        if (voiceSummary) voiceSummary.classList.remove('show');
        voiceMsgs.forEach(function(m) { m.classList.remove('show'); });
        // Email card arrives first, then each field reveals
        setTimeout(function() { if (voiceSummary) voiceSummary.classList.add('show'); }, 400);
        var fieldDelays = [1000, 2200, 3400, 4600];
        fieldDelays.forEach(function(d, i) {
          setTimeout(function() { if (voiceMsgs[i]) voiceMsgs[i].classList.add('show'); }, d);
        });
        setTimeout(runVoice, VOICE_LOOP);
      }
      if (voiceSummary) setTimeout(runVoice, 500);

      // 3. Missed-call SMS scene
      var scene = document.querySelector('[data-sms-scene]');
      if (scene) {
        var phoneScreens = {
          calling: scene.querySelector('[data-sms-phone="calling"]'),
          missed:  scene.querySelector('[data-sms-phone="missed"]'),
          sms:     scene.querySelector('[data-sms-phone="sms"]'),
        };
        var dashScreens = {
          calling: scene.querySelector('[data-sms-dash="calling"]'),
          missed:  scene.querySelector('[data-sms-dash="missed"]'),
          sms:     scene.querySelector('[data-sms-dash="sms"]'),
        };
        var dots     = Array.from(scene.querySelectorAll('[data-sms-dot]'));
        var line     = scene.querySelector('[data-sms-line]');
        var xbadge   = scene.querySelector('[data-sms-xbadge]');
        var fields   = Array.from(scene.querySelectorAll('[data-sms-dash-field]'));
        var SMS_LOOP = 10000;

        function setPhase(phase) {
          // Phone screens
          Object.keys(phoneScreens).forEach(function(k) {
            if (phoneScreens[k]) phoneScreens[k].classList.toggle('active', k === phase);
          });
          // Dashboard screens
          Object.keys(dashScreens).forEach(function(k) {
            if (dashScreens[k]) dashScreens[k].classList.toggle('active', k === phase);
          });
          // Connector
          if (phase === 'calling') {
            line.style.backgroundColor = '';
            line.classList.remove('bg-red-500/40');
            line.classList.add('bg-teal/25');
            dots.forEach(function(d) {
              d.classList.remove('animate-rtl', 'bg-red-500');
              d.classList.add('animate-ltr', 'bg-teal');
            });
            xbadge.classList.remove('show');
          } else if (phase === 'missed') {
            line.classList.remove('bg-teal/25');
            line.classList.add('bg-red-500/40');
            dots.forEach(function(d) {
              d.classList.remove('animate-ltr', 'animate-rtl');
              d.style.opacity = '0';
            });
            xbadge.classList.add('show');
          } else {
            line.classList.remove('bg-red-500/40');
            line.classList.add('bg-teal/25');
            xbadge.classList.remove('show');
            dots.forEach(function(d) {
              d.style.opacity = '';
              d.classList.remove('animate-ltr', 'bg-red-500');
              d.classList.add('animate-rtl', 'bg-teal');
            });
          }
        }

        function showFields(startIdx, count) {
          for (var i = startIdx; i < startIdx + count; i++) {
            (function(idx, delay) {
              setTimeout(function() {
                var f = scene.querySelector('[data-sms-dash-field="' + idx + '"]');
                if (f) f.classList.add('show');
              }, delay);
            })(i, (i - startIdx) * 600);
          }
        }

        function hideAllFields() {
          fields.forEach(function(f) { f.classList.remove('show'); });
        }

        function runSMS() {
          hideAllFields();
          // Phase 1: Calling (0-3s)
          setPhase('calling');
          showFields(0, 2);

          // Phase 2: Missed (3s-5.5s)
          setTimeout(function() {
            setPhase('missed');
            showFields(2, 3);
          }, 3000);

          // Phase 3: SMS sent (5.5s-8.5s)
          setTimeout(function() {
            setPhase('sms');
            showFields(5, 3);
          }, 5500);

          setTimeout(runSMS, SMS_LOOP);
        }

        setTimeout(runSMS, 600);
      }
    })();
  </script>

  <script is:inline>
    // Count-up animation for the $20K+ stat
    (() => {
      const statItems = document.querySelectorAll('.stat-item');
      // The 4th stat item (index 3) is $20K+
      const dollarStat = statItems[3]?.querySelector('p:first-child');
      if (!dollarStat) return;

      function countUp(el, end, durationMs) {
        const startTime = performance.now();
        function step(now) {
          const elapsed = now - startTime;
          const progress = Math.min(elapsed / durationMs, 1);
          // Ease-out cubic
          const eased = 1 - Math.pow(1 - progress, 3);
          const val = Math.floor(eased * end);
          el.textContent = '$' + val + 'K+';
          if (progress < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      }

      // Start the counter after the stat's fade-in delay (1.2s)
      setTimeout(() => countUp(dollarStat, 20, 1200), 1200);
    })();
  </script>

  <script is:inline>
    (() => {
      const list = document.querySelector('[data-compare-list]');
      if (!list) return;
      const rows = Array.from(list.querySelectorAll('.compare-row'));

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          rows.forEach((row, i) => {
            setTimeout(() => row.classList.add('visible'), i * 200);
          });
          observer.disconnect();
        });
      }, { threshold: 0.1 });

      observer.observe(list);
    })();
  </script>

