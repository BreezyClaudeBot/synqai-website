    <script is:inline>
      (() => {
        const root = document.querySelector('[data-industry-carousel]');
        if (!root) return;
        const slides = Array.from(root.querySelectorAll('[data-slide]'));
        const dots = Array.from(root.querySelectorAll('[data-dot]'));
        const prev = root.querySelector('[data-prev]');
        const next = root.querySelector('[data-next]');
        let cur = 0;
        const update = () => {
          slides.forEach((s, i) => { s.classList.toggle('hidden', i !== cur); s.classList.toggle('block', i === cur); });
          dots.forEach((d, i) => {
            d.setAttribute('aria-current', i === cur ? 'true' : 'false');
            d.classList.toggle('bg-teal', i === cur); d.classList.toggle('w-5', i === cur);
            d.classList.toggle('bg-stone-300', i !== cur); d.classList.toggle('w-1.5', i !== cur);
          });
        };
        prev?.addEventListener('click', () => { cur = (cur - 1 + slides.length) % slides.length; update(); resetAuto(); });
        next?.addEventListener('click', () => { cur = (cur + 1) % slides.length; update(); resetAuto(); });
        dots.forEach((d, i) => d.addEventListener('click', () => { cur = i; update(); resetAuto(); }));
        update();

        let autoTimer = setInterval(() => { cur = (cur + 1) % slides.length; update(); }, 4000);
        function resetAuto() { clearInterval(autoTimer); autoTimer = setInterval(() => { cur = (cur + 1) % slides.length; update(); }, 4000); }
      })();
    </script>



